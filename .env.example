# Figma Plugin Development Environment Variables
# Copy this file to .env and fill in your values

# Figma Access Token (optional)
# Used for Figma API testing during development
# Get yours at: https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=

# Plugin ID (optional)
# Set after publishing to Figma Community
# Used for manifest updates and release scripts
FIGMA_PLUGIN_ID=
